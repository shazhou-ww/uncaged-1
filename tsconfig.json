{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "lib": [
      "ES2022"
    ],
    "types": [
      "@cloudflare/workers-types/2023-07-01"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    ".wrangler"
  ]
}